# ============ Environment Files (CRITICAL) ============
.env
.env.*
!.env.example
*token.json*
*credentials.json*

# ============ Dependencies ============
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
venv/
.venv/

# ============ IDE and Editors ============
.idea/
.vscode/
*.swp
*.swo

# ============ Python ============
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ============ Testing ============
/coverage
.pytest_cache/
htmlcov/

# ============ Build Output ============
/build
dist/
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ============ Logs ============
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dump.rdb

# ============ System Files ============
.DS_Store
*.pem
Thumbs.db

# ============ Archives ============
*.zip
*.tar.gz
*.tar
*.tgz
*.pack
*.deb

# ============ Uploads (production data) ============
/uploads/*
!/uploads/.gitkeep

# ============ Other ============
.cache/
.vercel
chainlit.md
.chainlit
.ipynb_checkpoints/
