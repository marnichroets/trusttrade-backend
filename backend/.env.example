# TrustTrade Backend Environment Variables
# Copy this file to .env and fill in your values

# ============ DEPLOYMENT ENVIRONMENT ============
# Set to: development, staging, or production
# Controls default CORS origins and other environment-specific behavior
ENV=development

# ============ DATABASE ============
MONGO_URL=mongodb://localhost:27017
DB_NAME=trusttrade

# ============ CORS ============
# Comma-separated list of allowed frontend origins
# Whitespace is automatically stripped from each origin
# 
# Development (auto-defaults to localhost variants if not set):
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
#
# Staging (auto-defaults if not set):
# CORS_ORIGINS=https://staging.trusttradesa.co.za,https://trusttradesa.co.za
#
# Production (auto-defaults if not set):
# CORS_ORIGINS=https://trusttradesa.co.za
#
# Manual override (leave empty to use ENV-based defaults):
CORS_ORIGINS=

# ============ FRONTEND URL ============
# Used for email links and redirects
FRONTEND_URL=https://trusttradesa.co.za

# ============ TRADESAFE INTEGRATION ============
# TradeSafe escrow payment gateway (https://tradesafe.co.za)
TRADESAFE_CLIENT_ID=your_client_id_here
TRADESAFE_CLIENT_SECRET=your_client_secret_here
TRADESAFE_ENV=production
TRADESAFE_API_URL=https://api.tradesafe.co.za/graphql
TRADESAFE_AUTH_URL=https://auth.tradesafe.co.za/oauth/token
TRADESAFE_PAYMENT_URL=https://pay.tradesafe.co.za

# ============ EMAIL (POSTMARK) ============
# Postmark transactional email service (https://postmarkapp.com)
POSTMARK_API_KEY=your_postmark_api_key_here
POSTMARK_SENDER_EMAIL=noreply@yourdomain.com

# ============ SMS (ZOOM CONNECT / SMS MESSENGER) ============
# SMS Messenger / Zoom Connect for South Africa (https://smsmessenger.co.za)
SMS_MESSENGER_API_KEY=your_sms_api_key_here
SMS_MESSENGER_EMAIL=your_email@example.com
SMS_MESSENGER_API_URL=https://sms1.smsmessenger.co.za/app/api/rest/v1/sms/send

# ============ ADMIN ============
# Email address for system alerts
ADMIN_ALERT_EMAIL=admin@yourdomain.com
# Primary admin email (has full admin access)
ADMIN_EMAIL=admin@yourdomain.com


# ============ PAYMENT REDIRECT URLs ============
# URLs where users are redirected after payment
PAYMENT_SUCCESS_URL=https://your-domain.com/transaction/success
PAYMENT_FAILURE_URL=https://your-domain.com/transaction/failed
PAYMENT_CANCEL_URL=https://your-domain.com/transaction/cancelled
ADMIN_EMAIL=admin@yourdomain.com
